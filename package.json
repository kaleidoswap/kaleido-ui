{
  "name": "kaleido-ui",
  "version": "0.1.0",
  "description": "KaleidoSwap shared UI library — design tokens, web components (Tailwind + Radix), and React Native components extending WDK UI Kit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/web/index.cjs",
  "module": "./dist/web/index.js",
  "types": "./dist/web/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js",
      "require": "./dist/web/index.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js",
      "require": "./dist/tokens/index.cjs"
    },
    "./native": {
      "types": "./dist/native/index.d.ts",
      "import": "./dist/native/index.js",
      "require": "./dist/native/index.cjs"
    },
    "./tailwind": {
      "types": "./dist/tailwind/index.d.ts",
      "import": "./dist/tailwind/index.js",
      "require": "./dist/tailwind/index.cjs"
    },
    "./css": "./dist/css/kaleido-ui.css",
    "./css/v4": "./dist/css/kaleido-theme-v4.css"
  },
  "files": [
    "dist",
    "native",
    "tokens",
    "tailwind"
  ],
  "scripts": {
    "build": "tsup && mkdir -p dist/css && cp src/css/kaleido-ui.css dist/css/kaleido-ui.css && cp src/css/kaleido-theme-v4.css dist/css/kaleido-theme-v4.css",
    "dev": "tsup --watch",
    "showcase": "vite --config showcase/vite.config.ts",
    "showcase:build": "vite build --config showcase/vite.config.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tetherto/wdk-uikit-react-native": "^1.0.0-beta.2"
  },
  "peerDependencies": {
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "qrcode.react": "^3.0.0 || ^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.73.0",
    "tailwind-merge": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "@radix-ui/react-dialog": {
      "optional": true
    },
    "@radix-ui/react-label": {
      "optional": true
    },
    "@radix-ui/react-slot": {
      "optional": true
    },
    "@radix-ui/react-tabs": {
      "optional": true
    },
    "@radix-ui/react-toast": {
      "optional": true
    },
    "class-variance-authority": {
      "optional": true
    },
    "clsx": {
      "optional": true
    },
    "tailwind-merge": {
      "optional": true
    },
    "qrcode.react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-native": "^0.72.8",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "postcss": "^8.4.49",
    "qrcode.react": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.0.0",
    "typescript": "^5.9.0",
    "vite": "^5.4.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kaleidoswap/kaleido-ui.git"
  },
  "keywords": [
    "kaleidoswap",
    "ui",
    "design-tokens",
    "react",
    "react-native",
    "tailwind",
    "radix"
  ]
}
